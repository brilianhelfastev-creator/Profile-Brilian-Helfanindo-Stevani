# ============================================
# Backend Environment Variables - PRODUCTION
# ============================================
# Copy this to .env and update values for production

# Server Configuration
PORT=5001
NODE_ENV=production

# ============================================
# IMPORTANT: Update these for production!
# ============================================

# Database Configuration
# For remote database (Railway, Heroku, or VPS)
DB_HOST=your-database-host.com
DB_USER=app_user
DB_PASSWORD=your_strong_password_here
DB_NAME=profile_db
DB_PORT=3306

# CORS Configuration (set to your frontend domain)
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# Database Connection Settings
DB_CONNECTION_TIMEOUT=30000
DB_CONNECTION_LIMIT=10

# Retry Configuration (for production stability)
DB_RETRY_ATTEMPTS=5
DB_RETRY_DELAY=2000

# ============================================
# Examples:
# ============================================

# Example 1: Local MySQL
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=profile_db

# Example 2: Railway
# DB_HOST=prod-mysql.railway.internal
# DB_USER=admin
# DB_PASSWORD=your_railway_password
# DB_NAME=railway

# Example 3: Render
# DB_HOST=your-db-instance.render.com
# DB_USER=admin
# DB_PASSWORD=your_render_password
# DB_NAME=profile_db

# Example 4: Heroku with ClearDB
# DB_HOST=abcdef.cleardb.net
# DB_USER=abc123def
# DB_PASSWORD=your_cleardb_password
# DB_NAME=heroku_abc123def

# Example 5: AWS RDS
# DB_HOST=mydb.c9akciq32.us-east-1.rds.amazonaws.com
# DB_USER=admin
# DB_PASSWORD=your_rds_password
# DB_NAME=profile_db
